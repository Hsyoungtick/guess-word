# Vite 变量会打包进公开前端，禁止在此放置密钥
VITE_SUPABASE_FUNCTION_URL=https://PROJECT_REF.supabase.co/functions/v1/game
VITE_BASE_PATH=/guess-word/

# 以下仅为 Supabase Edge Function secrets 名称示例，请通过 supabase secrets set 配置

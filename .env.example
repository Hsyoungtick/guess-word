# Vite 变量会打包进公开前端，禁止在此放置密钥
VITE_SUPABASE_FUNCTION_URL=https://PROJECT_REF.supabase.co/functions/v1/game
VITE_BASE_PATH=/guess-word/

# 以下仅为 Supabase Edge Function secrets 名称示例，请通过 supabase secrets set 配置
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# GAME_SECRET=YOUR_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
# AI_CONFIG={"baseUrl":"https://api.example.com/v1","apiKey":"YOUR_AI_API_KEY","model":"YOUR_MODEL","temperature":0.1,"timeoutMs":20000}
# ALLOWED_ORIGIN=https://YOUR_NAME.github.io,http://localhost:5173
